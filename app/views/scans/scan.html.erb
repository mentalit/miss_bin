<%# app/views/scans/scan.html.erb %>
<div class="container py-3" style="max-width: 600px;">

  <%# Progress %>
  <div class="d-flex justify-content-between align-items-center mb-2">
    <h5 class="mb-0">Scanning locations</h5>
    <span class="badge bg-secondary fs-6"><%= @index + 1 %> / <%= @total %></span>
  </div>
  <div class="progress mb-3" style="height: 6px;">
    <div class="progress-bar" style="width: <%= ((@index.to_f / @total) * 100).round %>%"></div>
  </div>

  <%# Current location card %>
  <div class="card shadow-sm mb-3">
    <div class="card-body">
      <div class="row">
        <div class="col">
          <div class="text-muted small">Location</div>
          <div class="font-monospace fs-3 fw-bold"><%= @slid_h %></div>
        </div>
        <div class="col">
          <div class="text-muted small">Expected Art No</div>
          <div class="font-monospace fs-3 fw-bold"><%= @article&.artno || "—" %></div>
        </div>
      </div>
      <% if @article %>
        <hr class="my-2">
        <div class="text-muted small"><%= @article.artname %></div>
      <% end %>
    </div>
  </div>

  <%# Hidden camera elements — not shown to user %>
  <video id="camera_feed" autoplay playsinline muted style="display:none;"></video>
  <canvas id="capture_canvas" style="display:none;"></canvas>

  <%# Countdown bar — shown in auto mode %>
  <div id="auto_panel" class="mb-3">
    <div class="d-flex justify-content-between align-items-center mb-1">
      <small class="text-muted">Next scan in <span id="countdown">5</span>s</small>
      <small class="text-danger fw-bold" id="mismatch_counter"></small>
    </div>
    <div class="progress" style="height: 8px;">
      <div id="countdown_bar" class="progress-bar bg-info" style="width:100%;"></div>
    </div>
  </div>

  <%# Result flash %>
  <div id="result_flash" style="display:none;" class="card border-0 mb-3">
    <div id="result_header" class="card-header text-white fw-bold text-center fs-5"></div>
    <div class="card-body py-2">
      <dl class="row mb-0 small" id="result_body"></dl>
    </div>
  </div>

  <%# Error banner %>
  <div id="error_banner" class="alert alert-warning" style="display:none;"></div>

  <%# Controls %>
  <div class="d-grid gap-2">
    <div class="btn-group w-100">
      <button id="auto_btn"   class="btn btn-success btn-lg">⏱ Auto (5s)</button>
      <button id="manual_btn" class="btn btn-outline-secondary btn-lg">👆 Manual</button>
    </div>
    <button id="scan_btn" class="btn btn-primary btn-lg" style="display:none;">📷 Scan Now</button>
    <div class="d-flex gap-2">
      <%= link_to "⏭ Skip", skip_store_scans_path(@store),
            class: "btn btn-outline-secondary btn-sm flex-fill",
            data: { turbo: false } %>
      <%= link_to "🏁 End & See Results", results_store_scans_path(@store),
            class: "btn btn-outline-dark btn-sm flex-fill" %>
    </div>
  </div>
</div>

<script type="module">
  const storeId      = <%= @store.id %>;
  const csrf         = document.querySelector('meta[name="csrf-token"]').content;
  const INTERVAL     = 5000;

  const video        = document.getElementById("camera_feed");
  const canvas       = document.getElementById("capture_canvas");
  const autoBtn      = document.getElementById("auto_btn");
  const manualBtn    = document.getElementById("manual_btn");
  const scanBtn      = document.getElementById("scan_btn");
  const autoPanel    = document.getElementById("auto_panel");
  const countdownEl  = document.getElementById("countdown");
  const countdownBar = document.getElementById("countdown_bar");
  const resultFlash  = document.getElementById("result_flash");
  const resultHdr    = document.getElementById("result_header");
  const resultBody   = document.getElementById("result_body");
  const errorBanner  = document.getElementById("error_banner");
  const mismatchCtr  = document.getElementById("mismatch_counter");

  let autoMode      = true;
  let scanning      = false;
  let timer         = null;
  let tickTimer     = null;
  let mismatchCount = 0;

  // ── Start camera (hidden — only used for capture) ──
  async function startCamera() {
    try {
      const stream = await navigator.mediaDevices.getUserMedia({
        video: { facingMode: { ideal: "environment" }, width: { ideal: 1280 }, height: { ideal: 720 } }
      });
      video.srcObject = stream;
      await new Promise(resolve => video.addEventListener("loadedmetadata", resolve, { once: true }));
      canvas.width  = video.videoWidth;
      canvas.height = video.videoHeight;
    } catch (err) {
      showError("Camera error: " + err.message);
    }
  }

  // ── Capture frame from hidden video → base64 ──
  function captureBase64() {
    canvas.getContext("2d").drawImage(video, 0, 0, canvas.width, canvas.height);
    // Strip the data:image/jpeg;base64, prefix
    return canvas.toDataURL("image/jpeg", 0.85).split(",")[1];
  }

  // ── Mode toggle ──
  autoBtn.addEventListener("click", () => {
    if (autoMode) return;
    autoMode = true;
    autoBtn.className   = "btn btn-success btn-lg";
    manualBtn.className = "btn btn-outline-secondary btn-lg";
    scanBtn.style.display  = "none";
    autoPanel.style.display = "block";
    startCountdown();
  });

  manualBtn.addEventListener("click", () => {
    if (!autoMode) return;
    autoMode = false;
    stopCountdown();
    manualBtn.className = "btn btn-secondary btn-lg";
    autoBtn.className   = "btn btn-outline-success btn-lg";
    scanBtn.style.display   = "block";
    autoPanel.style.display = "none";
  });

  scanBtn.addEventListener("click", () => { if (!scanning) doScan(); });

  // Spacebar fires in either mode
  document.addEventListener("keydown", (e) => {
    if (e.code === "Space" && !scanning) {
      e.preventDefault();
      if (autoMode) stopCountdown();
      doScan();
    }
  });

  // ── Countdown ──
  function startCountdown() {
    let secondsLeft = INTERVAL / 1000;
    countdownEl.textContent = secondsLeft;
    countdownBar.style.transition = "none";
    countdownBar.style.width = "100%";

    requestAnimationFrame(() => requestAnimationFrame(() => {
      countdownBar.style.transition = `width ${INTERVAL}ms linear`;
      countdownBar.style.width = "0%";
    }));

    tickTimer = setInterval(() => {
      secondsLeft--;
      countdownEl.textContent = secondsLeft;
    }, 1000);

    timer = setTimeout(doScan, INTERVAL);
  }

  function stopCountdown() {
    clearTimeout(timer);
    clearInterval(tickTimer);
    countdownBar.style.transition = "none";
    countdownBar.style.width = "100%";
  }

  // ── Main scan ──
  async function doScan() {
    if (scanning) return;
    scanning = true;
    stopCountdown();
    errorBanner.style.display = "none";
    resultFlash.style.display = "none";

    try {
      const image = captureBase64();

      const res  = await fetch(`/stores/${storeId}/scans/capture`, {
        method:  "POST",
        headers: {
          "X-CSRF-Token": csrf,
          "Content-Type": "application/json"
        },
        body: JSON.stringify({ image })
      });

      const data = await res.json();

      if (!res.ok) {
        showError(data.error || `Error ${res.status}`);
        scanning = false;
        if (autoMode) startCountdown();
        return;
      }

      showResult(data);

      if (!data.match) {
        mismatchCount++;
        mismatchCtr.textContent = `⚠ ${mismatchCount} mismatch${mismatchCount === 1 ? "" : "es"}`;
      }

      if (data.done) {
        setTimeout(() => { window.location = `/stores/${storeId}/scans/results`; }, 1500);
      } else {
        setTimeout(() => { window.location = `/stores/${storeId}/scans/scan`; }, 1200);
      }

    } catch (err) {
      showError("Network error: " + err.message);
      scanning = false;
      if (autoMode) startCountdown();
    }
  }

  function showResult(data) {
    resultFlash.style.display = "block";
    if (data.confidence === "unreadable") {
      resultHdr.textContent      = "⚠️ Unreadable — recorded";
      resultHdr.style.background = "#fd7e14";
    } else if (data.match) {
      resultHdr.textContent      = "✅ Match";
      resultHdr.style.background = "#198754";
    } else {
      resultHdr.textContent      = "❌ Mismatch — recorded";
      resultHdr.style.background = "#dc3545";
    }
    resultBody.innerHTML = `
      <dt class="col-5">Expected</dt><dd class="col-7 font-monospace">${data.expected ?? "—"}</dd>
      <dt class="col-5">Detected</dt><dd class="col-7 font-monospace">${data.detected ?? "—"}</dd>
    `;
  }

  function showError(msg) {
    errorBanner.textContent   = msg;
    errorBanner.style.display = "block";
  }

  // ── Init ──
  await startCamera();
  startCountdown();
</script>
